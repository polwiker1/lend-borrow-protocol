# Testnet deploy configuration
# Copy this file to .env and fill real values. Never commit .env.

# Private key of the deployer wallet with testnet gas.
PRIVATE_KEY=

# RPC URL for the selected testnet.
# Example: Sepolia, Base Sepolia, Arbitrum Sepolia, etc.
RPC_URL=

# Optional: multisig/admin wallet that will own the admin contracts after deploy.
# If empty, the deployer wallet becomes the admin.
ADMIN_ADDRESS=

# Optional ERC1155 metadata base URI.
TICKET_BASE_URI=ipfs://agro-ticket/{id}.json

# Last Arbitrum Sepolia study deploy, chainId 421614.
# These are public contract addresses, useful for the local panel.
DEPLOYED_CHAIN_ID=421614
DEPLOYED_ADMIN_ADDRESS=0x521125be95c5679539aB07582F55F0040975A047
DEPLOYED_MOCK_PRICE_ORACLE=0x32dE2A73d742731D721d314D914DBf95bAB40b46
DEPLOYED_LENDING_PROTOCOL=0xd56FDA75E70F2C15376ec48f612C4405fF64b796
DEPLOYED_AGRO_TICKET_1155=0xC63fDCE9feAd8B71E7D8E72A0bD90d9B3BC2b8ad
DEPLOYED_AGRO_TICKET_RECEIPT_VAULT=0x2D0B31405d7E6151E2a55b0318BDb1c3FD68B4a1
DEPLOYED_AUSD=0x34155Bd9688756fDDcCccc0A01fa993661A840CC
DEPLOYED_WTK=0xDDB5C2Aa89Ad4E4dF668dC42c242618C0456650b

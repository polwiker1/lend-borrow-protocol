# Testnet deploy configuration
# Copy this file to .env and fill real values. Never commit .env.

# Private key of the deployer wallet with testnet gas.
PRIVATE_KEY=

# RPC URL for the selected testnet.
# Example: Sepolia, Base Sepolia, Arbitrum Sepolia, etc.
RPC_URL=

# Optional: multisig/admin wallet that will own the admin contracts after deploy.
# If empty, the deployer wallet becomes the admin.
ADMIN_ADDRESS=

# Optional ERC1155 metadata base URI.
TICKET_BASE_URI=ipfs://agro-ticket/{id}.json
